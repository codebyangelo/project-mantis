# Python cache
__pycache__/
*.py[cod]
*$py.class

# Mantis Artifacts & Logs
execution.log
thoughts.txt
PM_MITRE_Report_*.md

# Mantis Caching
orchestrator_cache.json
ioc_store.json
evidence_cache/
*cache.json

# Environment files
.env
.DS_Store

# Scratch files
*.txt
*.dd
*.raw
*.e01
